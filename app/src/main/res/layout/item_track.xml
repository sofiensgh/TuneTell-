<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#111128"
    app:rippleColor="#1A00D2FF"
    app:strokeWidth="1dp"
    app:strokeColor="#1A00D2FF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Artwork -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/thumbnailCard"
            android:layout_width="56dp"
            android:layout_height="56dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="#1A1A3A"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/ivArtwork"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/tvSongIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="🎵"
                android:textSize="20sp"
                android:gravity="center"
                android:visibility="gone"
                android:background="#1A1A3A" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Cyan left accent bar -->
        <View
            android:id="@+id/accentBar"
            android:layout_width="3dp"
            android:layout_height="0dp"
            android:background="#00D2FF"
            android:layout_marginStart="12dp"
            app:layout_constraintStart_toEndOf="@id/thumbnailCard"
            app:layout_constraintTop_toTopOf="@id/thumbnailCard"
            app:layout_constraintBottom_toBottomOf="@id/thumbnailCard" />

        <!-- Song Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:text="Song Title"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="1"
            app:layout_constraintEnd_toStartOf="@id/ivMore"
            app:layout_constraintStart_toEndOf="@id/accentBar"
            app:layout_constraintTop_toTopOf="@id/thumbnailCard"
            app:layout_constraintBottom_toTopOf="@id/tvArtist"
            app:layout_constraintVertical_chainStyle="packed" />

        <!-- Artist Name -->
        <TextView
            android:id="@+id/tvArtist"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Artist Name"
            android:textColor="#8899AA"
            android:textSize="13sp"
            android:ellipsize="end"
            android:maxLines="1"
            app:layout_constraintEnd_toEndOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="@id/tvTitle"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintBottom_toBottomOf="@id/thumbnailCard" />

        <!-- More Options -->
        <ImageView
            android:id="@+id/ivMore"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="6dp"
            android:src="@android:drawable/ic_menu_more"
            app:tint="#8899AA"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>